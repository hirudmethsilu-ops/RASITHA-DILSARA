# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# PLAID_CLIENT_ID: Your Plaid API developer Client ID
PLAID_CLIENT_ID="MY_PLAID_CLIENT_ID"
# PLAID_SECRET: Your Plaid API developer Secret key
PLAID_SECRET="MY_PLAID_SECRET"
# PLAID_ENVIRONMENT: Plaid environment to connect to (sandbox, development, or production)
PLAID_ENVIRONMENT=sandbox
